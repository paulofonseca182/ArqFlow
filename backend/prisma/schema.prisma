generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Client {
  id        String   @id @default(cuid())
  name      String
  status    String   @default("NEW_CONTACT")
  phone     String?
  whatsapp  String?
  email     String?  @unique
  cpfCnpj   String?
  address   String?
  city      String?
  state     String?
  source    String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projects  Project[]
  budgets   Budget[]
  payments  Payment[]
  visits    Visit[]

  @@index([name])
  @@index([status])
}

model Project {
  id                   String    @id @default(cuid())
  clientId             String
  budgetId             String?   @unique
  name                 String
  type                 String
  workAddress          String?
  area                 Decimal?
  contractedAmount     Decimal?
  startsAt             DateTime?
  expectedDeliveryDate DateTime?
  status               String    @default("CONTRACT_IN_PROGRESS")
  description          String?
  notes                String?
  internalNotes        String?
  origin               String    @default("MANUAL")
  manualReason         String?
  approvedAt           DateTime?
  convertedAt          DateTime?
  pinned               Boolean   @default(false)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  client          Client        @relation(fields: [clientId], references: [id], onDelete: Restrict)
  budget          Budget?       @relation("ProjectOriginBudget", fields: [budgetId], references: [id], onDelete: SetNull)
  convertedBudget Budget?       @relation("BudgetConvertedProject")
  steps           ProjectStep[]
  budgets         Budget[]      @relation("ProjectBudgets")
  payments        Payment[]
  tasks           Task[]
  visits          Visit[]

  @@index([clientId])
  @@index([budgetId])
  @@index([origin])
  @@index([status])
  @@index([type])
}

model ProjectStep {
  id          String    @id @default(cuid())
  projectId   String
  name        String
  description String?
  sortOrder   Int
  startsAt    DateTime?
  dueDate     DateTime?
  completedAt DateTime?
  status      String    @default("PENDING")
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([status])
  @@unique([projectId, sortOrder])
}

model Budget {
  id            String    @id @default(cuid())
  clientId      String
  projectId     String?
  convertedProjectId String? @unique
  title         String
  serviceType   String
  description   String?
  totalAmount   Decimal   @default(0)
  discount      Decimal   @default(0)
  finalAmount   Decimal   @default(0)
  paymentMethod String?
  expiresAt     DateTime?
  status        String    @default("DRAFT")
  approvedAt    DateTime?
  convertedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  client           Client       @relation(fields: [clientId], references: [id], onDelete: Restrict)
  project          Project?     @relation("ProjectBudgets", fields: [projectId], references: [id], onDelete: SetNull)
  convertedProject Project?     @relation("BudgetConvertedProject", fields: [convertedProjectId], references: [id], onDelete: SetNull)
  originatedProject Project?    @relation("ProjectOriginBudget")
  items            BudgetItem[]

  @@index([clientId])
  @@index([projectId])
  @@index([convertedProjectId])
  @@index([status])
}

model BudgetItem {
  id          String  @id @default(cuid())
  budgetId    String
  description String
  quantity    Decimal
  unitAmount  Decimal
  totalAmount Decimal

  budget Budget @relation(fields: [budgetId], references: [id], onDelete: Cascade)

  @@index([budgetId])
}

model Payment {
  id            String    @id @default(cuid())
  projectId     String
  clientId      String
  description   String
  amount        Decimal
  paidAmount    Decimal   @default(0)
  installment   Int?
  dueDate       DateTime
  paidAt        DateTime?
  paymentMethod String?
  status        String    @default("RECEIVABLE")
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Restrict)
  client  Client  @relation(fields: [clientId], references: [id], onDelete: Restrict)

  @@index([projectId])
  @@index([clientId])
  @@index([status])
  @@index([dueDate])
}

model Task {
  id          String    @id @default(cuid())
  projectId   String?
  title       String
  description String?
  assignee    String?
  dueDate     DateTime?
  priority    String    @default("MEDIUM")
  status      String    @default("PENDING")
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([status])
  @@index([priority])
}

model Visit {
  id        String   @id @default(cuid())
  clientId  String
  projectId String?
  type      String
  date      DateTime
  time      String?
  address   String?
  amount    Decimal?
  status    String   @default("SCHEDULED")
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client  Client   @relation(fields: [clientId], references: [id], onDelete: Restrict)
  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([clientId])
  @@index([projectId])
  @@index([status])
  @@index([date])
}
